# API Keys for AI-powered insights
# You can use either OpenAI or Anthropic (Claude)

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (Claude)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Choose which model to use (default: claude if ANTHROPIC_API_KEY is set, otherwise gpt-4o-mini)
# Options: gpt-4o-mini, gpt-4o, claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
# AI_MODEL=claude-3-5-sonnet-20241022
